{
  "name": "mukesh-sport-api",
  "version": "1.0.0",
  "description": "Mukesh Sport - Staff API for installment & repair management",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/db/knexfile.js",
    "seed": "knex seed:run --knexfile src/db/knexfile.js",
    "build": "echo 'No build step'",
    "render-postdeploy": "knex migrate:latest --knexfile src/db/knexfile.js && knex seed:run --knexfile src/db/knexfile.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
